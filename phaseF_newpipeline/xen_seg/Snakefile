rule convert_to_anndata:
    input:
        norm_rds = "norm/RA_orig_seg_lognorm.rds",
    output:
        norm_anndata = "norm/RA_orig_seg_lognorm.h5ad",
    params:
        method = "lognorm"
    threads: 1
    conda: "scconverter"
    shell:
        """
        Rscript  ../../bin/convert_seurat_to_adata.R norm/RA_orig_seg_lognorm.rds --output norm/RA
        """


for cell_file, cell_label, cell_type in zip(['../../data/so_myeloid.rds', '../../data/so_t_nk.rds', '../../data/so_b_plasma.rds'], ['Macrophage', 'T', 'B'], ['myeloid', 't_nk', 'b_plasma']):
    rule:
        name: f"subset_{cell_type}_kpmp"
        input:
            kpmp = cell_file
        output:
            subset_seu = f"kpmp.sub.ref.{cell_label}.rds",
            subset_sc = f"kpmp_subset_{cell_label}.ref.rds"
        conda: "spatial"
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/subset_cells.R  --output kidney_subset_{params.cell_label} --cell {params.cell_label} {input.kpmp}
            """

    rule:
        name: f"subset_{cell_type}_amp2"
        input:
            amp2 = cell_file
        output:
            subset_seu = f"sub.ref.{cell_label}.rds",
            subset_sc = f"RA_subset_{cell_label}.ref.rds"
        conda: "spatial"
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/subset_cells.R  --output RA_subset_{params.cell_label} --cell {params.cell_label} {input.amp2}
            """
    
    rule:
        name: f"subset_{cell_type}_xenium"
        input:
            xen = rules.normalize_rds2_singlet.output.norm_rds,
            meta_tsv = rules.extract_meta.output.meta_tsv
        output:
            subset_sc = f"RA_subset_{cell_label}_xen_singlet.rds"
        conda: "spatial"
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/match_celltypes.R  --output RA_subset_{params.cell_label}_xen_singlet --meta {input.meta_tsv} --cell "{params.cell_label}"  {input.xen} 
            """
    
    rule:
        name: f"subset_{cell_type}_xenium_dbl"
        input:
            xen = rules.normalize_rds2_dbl.output.norm_rds,
            meta_tsv = rules.extract_meta.output.meta_tsv
        output:
            subset_sc_dbl = f"RA_subset_{cell_label}_xen_dbl.rds"
        conda: "spatial"
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/match_celltypes.R  --output RA_subset_{params.cell_label}_xen_dbl --meta {input.meta_tsv} --cell "{params.cell_label}" {input.xen} 
            """
    
    rule:
        name: f"{cell_type}_singleR_annot"
        input:
            xen = f"RA_subset_{cell_label}_xen_singlet.rds",
            amp2 = f"sub.ref.{cell_label}.rds",
        output:
            xen_annot = f"RA_subset_{cell_label}_xen_singlet_singleR.rds",
            xen_sc_seu = f"RA_subset_{cell_label}_xen_singlet_mergedsc.rds"
        conda: "spatial"
        threads: 24
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/run_singleR.R  --output RA_subset_{params.cell_label}_xen_singlet {input.amp2} {input.xen} 
            """
    
    rule:
        name: f"integrate_sc_xenium_singlet_{cell_label}"
        input:
            xen = f"RA_subset_{cell_label}_xen_singlet.rds",
            amp2 = f"sub.ref.{cell_label}.rds",
            xen_sc_seu = f"RA_subset_{cell_label}_xen_singlet_mergedsc.rds"
        output:
            xen_sc_integrate = f"RA_integrate_{cell_label}_singlet_merged_annotated_sc.rds"
        conda: "spatial"
        threads: 10
        params: cell_label=cell_label
        shell:
            """
            Rscript ../../bin/run_integration.R --output RA_integrate_{params.cell_label}_singlet {input.amp2} {input.xen} {input.xen_sc_seu}
            """
    
