rule extract_meta:
    input:
        rds = "/data/wei/qq06/xenium/data/miles/shapes_seur_kidney_v5.rds"
    output:
        meta_tsv = "kidney_metadata.tsv",
        meta_qc = "kidney_qc.pdf"
    params:
        prefix = "kidney"
    threads: 1
    conda: "spatial"
    shell:
        """
        Rscript ../../bin/fetch_meta_data.R --output {params.prefix} {input.rds}
        """

rule reprocess_individual_xenium:
    input:
        case = "../../data/kidney/{group}/{sample}"
    output:
        simp_rds = "{group}_rds/{sample}_orig_seg.rds",
        simp_tsv = "{group}_rds/{sample}_orig_seg_meta.tsv"
    threads: 1
    conda: "spatial"
    shell:
        """
        Rscript ../../bin/extract_xenium.R --output {wildcards.group}_rds/{wildcards.sample} {input.case}
        """

