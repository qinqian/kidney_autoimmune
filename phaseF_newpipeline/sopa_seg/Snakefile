rule extract_meta:
    input:
        rds = "/data/wei/qq06/xenium/data/miles/shapes_seur_kidney_v5.rds"
    output:
        meta_tsv = "kidney_metadata.tsv",
        meta_qc = "kidney_qc.pdf"
    params:
        prefix = "kidney"
    threads: 1
    conda: "spatial"
    shell:
        """
        Rscript ../../bin/fetch_meta_data.R --output {params.prefix} {input.rds}
        """


rule process_xenium_sopa:
    input:
        case = "../../phaseA5_sopa/{group}/{sample}"
    output:
        simp_h5ad = "{group}_adata/{sample}_orig_seg.h5ad",
    threads: 1
    conda: "sopa"
    shell:
        """
        python ../../bin/extract_sopa.py -p {wildcards.group}_adata/{wildcards.sample} -d {input.case}
        """

rule agg_h5ad:
    input:
        simp_h5ad = expand("{group}_adata/{sample}_orig_seg.h5ad", zip, group=groups, sample=samples1+samples2)
    output:
        agg_rds = "comb_h5ad/kidney_orig_seg_merged.h5ad"
    threads: 1
    conda: "sopa"
    shell:
        """
        python ../../bin/combine_sopa.py -p comb_h5ad/kidney -d {input.simp_h5ad}
        """

rule convert_to_seurat:
    input:
        norm_rds = "comb_h5ad/kidney_orig_seg_merged.h5ad"
    output:
        norm_anndata = "comb_h5ad/kidney_orig_seg_merged.rds"
    params:
        method = "lognorm"
    threads: 1
    conda: "scconverter"
    shell:
        """
        Rscript  ../../bin/convert_adata_to_seurat.R {input.norm_rds} --output {output.norm_anndata}
        """

