rule singleR_annot_new_atlas3:
    input:
        xen = "RA_mat_objs/RA_orig_seg_lognorm_singlet.rds",
        amp2 = "0f95993d-1bbc-427e-8f5c-14ccf630ef26_KPMP_PREMIERE_SC_version1.5_ForExplorer_withRC.032624.rds",
    output:
        xen_annot = "res2_short_KPMP_xen_singlet_singleR.rds",
        xen_sc_seu = "res2_short_KPMP_xen_singlet_mergedsc_short.rds",
        xen_sc_seu2 = "res2_short_KPMP_xen_singlet_xenium_renorm_singleR.rds"
    conda: "spatial"
    threads: 24
    shell:
        """

        Rscript ../../bin/run_singleR_newatlas.R --resolution 2.0 --method cluster --celltype cell_type  --output res2_short_KPMP_xen_singlet {input.amp2} {input.xen} 

        """


