         nn2_label2 = "../xen_seg/output/KPMP_integrate_singlet_umap_umapnn_labels_umap.rds"
    output:
         label = "output/KPMP_integrate_singlet_comp_all_Rplots.pdf"
    conda: "spatial"
    threads: 1
    shell:
         """

         Rscript ../../bin/run_pseudobulk_comp.R --output KPMP_integrate_singlet_comp_all {input.nn1_label} {input.nn2_label} {input.singleR_label} {input.nn1_label2} {input.nn2_label2} {input.singleR_label2}

         """


